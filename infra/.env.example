# Copy to infra/.env and fill in real values. NEVER commit infra/.env.
# These values are consumed by docker-compose.yml (interpolation + container env).

# --- Postgres ---
POSTGRES_USER=opscanner
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_DB=opscanner
# Host port Postgres is published on (container is always 5432).
POSTGRES_PORT=5432

# --- API ---
# Host port the API is published on (container always listens on 3000).
API_PORT=3022
# Comma-separated allowed origins, or "*" for any.
CORS_ORIGIN=*
# Max requests per IP per minute.
RATE_LIMIT_MAX=300

# Connection string used by the API container AND for `prisma migrate deploy`
# at startup. Host is the compose service name "postgres".
DATABASE_URL=postgresql://opscanner:change_me_in_real_env@postgres:5432/opscanner?schema=public

# --- Auth (used from Phase 2 onward; generate long random strings, min 16 chars) ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# --- Ingestion source keys (used from Phase 1) ---
APITCG_API_KEY=
