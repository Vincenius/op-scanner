# Server config for running the API / Prisma OUTSIDE Docker (e.g. `npm run dev:server`
# or local `prisma migrate dev`). The host is "localhost" because Postgres is
# published to your machine by docker compose. Inside the compose network the
# API instead uses the values from infra/.env (host = "postgres").

NODE_ENV=development
HOST=0.0.0.0
PORT=3022
CORS_ORIGIN=*
# Max requests per IP per minute.
RATE_LIMIT_MAX=300
# On-disk cache for proxied card thumbnails/full art.
IMAGE_CACHE_DIR=.image-cache

# Auth (generate long random strings; min 16 chars)
JWT_ACCESS_SECRET=dev_access_secret_change_me_please_32+
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please_32
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

DATABASE_URL=postgresql://opscanner:change_me_in_real_env@localhost:5433/opscanner?schema=public
