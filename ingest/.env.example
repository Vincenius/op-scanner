# Ingestion job configuration (used from Phase 1 onward).

# Same database the API uses. Host is "localhost" when running the job from your
# machine against the compose-published Postgres; "postgres" when run inside the
# compose network.
DATABASE_URL=postgresql://opscanner:change_me_in_real_env@localhost:5432/opscanner?schema=public

# --- Source API keys (Phase 1) ---
# apitcg.com — free key, used for card metadata + official Bandai image URLs.
APITCG_API_KEY=
# optcgapi.com has daily rate limits — cache aggressively (no key required).

# --- pHash precompute (optional; `npm run ingest -- phash [setCode]`) ---
# PHASH_LIMIT=    # cap the number of variants hashed in one run
# PHASH_FORCE=    # set to 1 to recompute hashes that already exist
